#!/bin/sh
# -*- mode: sh -*-

git_cd()
{
    git_cd=$(git rev-parse --absolute-git-dir --is-bare-repository 2>/dev/null)
    if [ $? -ne 0 ] || [ -z "$git_cd" ];  then
        echo >&2 "not inside git repository"
        return 1
    fi

    case $git_cd in
        *true)
            git_cd="${git_cd%?true}"
            ;;
        *false)
            git_cd="${git_cd%/.git?false}"
            ;;
    esac

    case $1 in
        -) case "$OLDPWD" in
               "$git_cd"/*) cd - ;;
               *) echo >&2 "not inside git repository"
                  return 1
                  ;;
           esac ;;
        /*) cd "$git_cd/$1" ;;
        .|./*|..|../*) cd "$1" ;;
        *) cd "$git_cd/$1" ;;
    esac
}

git_cd "$@"
